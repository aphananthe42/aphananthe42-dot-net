---
import { Image } from "astro:assets";
import MainIcon from "../images/main_icon.png";
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionLayout from "../layouts/SectionLayout.astro";
import Separator from "../components/Separator.astro";
import LinkLogo from "../components/LinkLogo.astro";
import WorkShowcase from "../components/WorkShowcase.astro";
import TechStackLogo from "../components/TechStackLogo.astro";
---

<BaseLayout>
	<Image
		class="w-1/3 xl:w-1/12 aspect-square mx-auto mt-20 rounded-full"
		src={MainIcon}
		alt="aphananthe42のアイコン"
	/>
	<h1
		class="text-white text-3xl lg:text-6xl text-center font-roboto font-bold mt-9 lg:mt-20"
	>
		aphananthe42
	</h1>
	<div class="flex justify-center gap-6 lg:gap-24 mt-6 lg:mt-12">
		<LinkLogo href="https://github.com/aphananthe42" linkType="GitHub" />
		<LinkLogo href="https://x.com/aphananthe42" linkType="X" />
		<LinkLogo href="https://zenn.dev/aphananthe42" linkType="Zenn" />
		<LinkLogo
			href="https://atcoder.jp/users/aphananthe42"
			linkType="AtCoder"
		/>
	</div>
	<div class="flex justify-center mt-6 lg:mt-12">
    	<a href="/diary/" class="group relative inline-block px-5 py-2 border-2 border-zinc-700 rounded-md transition-all duration-300 hover:border-zinc-200">
        	<p class="text-xl lg:text-3xl text-zinc-300 font-mono font-bold group-hover:text-white flex items-center gap-1">
            	<span class="text-zinc-500">$</span>
				cd ~/diary
            	<span class="w-2.5 h-6 lg:h-8 bg-zinc-300 group-hover:bg-white animate-pulse ml-1"></span>
        	</p>
    	</a>
	</div>
	<Separator/>
	<SectionLayout title="Works">
		<div class="xl:w-2/4 mx-auto">
			<ul class="list-disc marker:text-white ml-4 space-y-12">
				<li>
					<WorkShowcase
						title="aphananthe42.net"
						href="https://aphananthe42.net"
					>
						<Fragment slot="description">
							That's this. <br />
							aphananthe42.net is my personal website.
						</Fragment>
						<Fragment slot="tech-stacks">
							<TechStackLogo
								href="https://astro.build"
								linkType="Astro"
							/>
							<TechStackLogo
								href="https://www.typescriptlang.org"
								linkType="TypeScript"
							/>
							<TechStackLogo
								href="https://tailwindcss.com"
								linkType="TailwindCSS"
							/>
							<TechStackLogo
								href="https://www.cloudflare.com"
								linkType="Cloudflare"
							/>
						</Fragment>
					</WorkShowcase>
				</li>
				<li>
					<WorkShowcase title="AI Frame" href="https://apps.apple.com/ja/app/ai-frame-art-on-widget/id6740455268">
						<Fragment slot="description">
							iOS App that lets you display AI-generated art on your home screen.
						</Fragment>
						<Fragment slot="tech-stacks">
							<TechStackLogo
								href="https://developer.apple.com/jp/swift"
								linkType="Swift"
							/>
							<TechStackLogo
								href="https://developer.apple.com/jp/xcode-cloud"
								linkType="XcodeCloud"
							/>
							<TechStackLogo
								href="https://firebase.google.com/?hl=en"
								linkType="Firebase"
							/>
						</Fragment>
					</WorkShowcase>
				</li>
			</ul>
		</div>
	</SectionLayout>
	<Separator/>
	<SectionLayout title="Contact">
		<div
			class="xl:w-2/4 mx-auto text-md lg:text-xl text-white font-roboto font-normal mt-4"
		>
			<p>
				Feel free to contact me via
				<a href="https://x.com/aphananthe42" class="text-blue-500">
					DM on X
				</a> or
				<a href="mailto:contact@aphananthe42.net" class="text-blue-500">
					email
				</a>.
			</p>
			<p>
				PGP Key is
				<a href="/pgp" class="text-blue-500">here</a>
				.
			</p>
		</div>
	</SectionLayout>
</BaseLayout>
